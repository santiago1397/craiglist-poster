# --- Public hostnames (Traefik Host() rules) ---
API_HOST=api.craigslist.yourdomain.com
WEB_HOST=craigslist.yourdomain.com

# --- Database (native Postgres on the VPS host, per SERVER_SETUP.md Option A) ---
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_USER=craigslist
POSTGRES_PASSWORD=change-me-strong-random-password
POSTGRES_DB=craigslist

# --- Admin login (single user) ---
ADMIN_EMAIL=you@example.com
# Generate:  docker compose -f docker-compose.prod.yml run --rm --entrypoint hash-password api
#   or from a local backend checkout:  cd backend && uv run hash-password
ADMIN_PASSWORD_HASH=$argon2id$v=19$m=65536,t=3,p=4$...

# --- Session ---
# 32+ random hex chars. Generate:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-32-byte-random-hex-string
JWT_ALGORITHM=HS256
JWT_TTL_DAYS=30
# Parent domain so the cookie is shared between craigslist.<domain> and api.craigslist.<domain>.
# Use a leading dot: ".yourdomain.com"
COOKIE_DOMAIN=.yourdomain.com
COOKIE_NAME=cl_admin_session
COOKIE_SECURE=true

# --- Windows → VPS ingest bearer token ---
# Generate: openssl rand -hex 32
INGEST_BEARER_TOKEN=change-me-to-a-strong-random-token

# --- CORS ---
CORS_ORIGINS=https://craigslist.yourdomain.com

# --- Ops ---
LOG_LEVEL=INFO
DISPLAY_TZ=America/New_York
