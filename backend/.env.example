# --- Database ---
# When running in Docker on the VPS, POSTGRES_HOST=host.docker.internal
# targets the native Postgres on the host per SERVER_SETUP.md Option A.
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_USER=craigslist
POSTGRES_PASSWORD=change-me
POSTGRES_DB=craigslist

# --- Admin login (single user) ---
ADMIN_EMAIL=you@example.com
# Run: uv run hash-password  (inside backend/) and paste output here.
ADMIN_PASSWORD_HASH=$argon2id$v=19$m=65536,t=3,p=4$...

# --- Session ---
# 32+ random chars. Generate with:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-32-byte-random-hex-string-goes-here
JWT_ALGORITHM=HS256
JWT_TTL_DAYS=30
# Set to the parent domain so the cookie is shared between the SPA and API
# sub-domains (e.g. ".yourdomain.com"). Leave empty for local dev.
COOKIE_DOMAIN=
COOKIE_NAME=cl_admin_session
COOKIE_SECURE=true

# --- Windows → VPS ingest ---
# 32+ random chars. Generate with:  openssl rand -hex 32
INGEST_BEARER_TOKEN=change-me-to-a-strong-random-token

# --- CORS ---
# Comma-separated origins allowed by the browser JS. Include the frontend URL.
CORS_ORIGINS=https://craigslist.yourdomain.com

# --- Ops ---
LOG_LEVEL=INFO
DISPLAY_TZ=America/New_York
