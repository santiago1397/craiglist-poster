# Only used at `vite build` time. Prefix must start with VITE_ to be exposed.
# Where the SPA sends its API calls (production).
VITE_API_BASE_URL=https://api.craigslist.yourdomain.com

# Local dev proxy target (see vite.config.ts). Only used by `vite` / `npm run dev`.
VITE_API_PROXY=http://localhost:8000
